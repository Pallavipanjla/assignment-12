<%- include("partials/header") %>

<div class="main-content">

    <div class="top-section">

        <h1>All Students</h1>

        <form action="/students" method="GET">

            <input
                type="text"
                name="search"
                placeholder="Search by name, course or city"
                value="<%= search %>"
            >

            <button type="submit">Search</button>

        </form>

    </div>

    <table>

        <thead>

            <tr>
                <th>Name</th>
                <th>Roll No</th>
                <th>Course</th>
                <th>Age</th>
                <th>Email</th>
                <th>City</th>
                <th>Actions</th>
            </tr>

        </thead>

        <tbody>

        <% students.forEach(student => { %>

            <tr>

                <td><%= student.name %></td>
                <td><%= student.rollno %></td>
                <td><%= student.course %></td>
                <td><%= student.age %></td>
                <td><%= student.email %></td>
                <td><%= student.city %></td>

                <td>

                    <a class="view" href="/students/view/<%= student._id %>">View</a>

                    <a class="edit" href="/students/edit/<%= student._id %>">Edit</a>

                    <a class="delete" href="/students/delete/<%= student._id %>">Delete</a>

                </td>

            </tr>

        <% }) %>

        </tbody>

    </table>

</div>

<%- include("partials/footer") %>